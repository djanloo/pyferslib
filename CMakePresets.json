{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "binaryDir": "${sourceDir}/build",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "lib-only",
            "binaryDir": "${sourceDir}/build-lib",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_PYTHON_BINDINGS": "OFF"
            }
        },
        {
        "name": "windows-cross",
        "binaryDir": "${sourceDir}/build-win",
        "generator": "Ninja",
        "toolchainFile": "${sourceDir}/cmake/mingw-toolchain.cmake",
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release",
            "BUILD_PYTHON_BINDINGS": "ON"
        }
}
    ],
    "buildPresets": [
        {"name": "default",  "configurePreset": "default"},
        {"name": "lib-only", "configurePreset": "lib-only"},
        {"name": "windows-cross", "configurePreset": "windows-cross"}
    ]
}